    "esbuild@0.21.5": true,
    "esbuild@0.25.12": true,
    "esbuild@0.17.19": true,
    "workerd@1.20260625.1": true,
    "workerd@1.20250718.0": true,
    "sharp@0.34.5": true,
    "sharp@0.33.5": true
  }
